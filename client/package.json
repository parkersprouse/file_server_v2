{
  "name": "web_file_browser_client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "browserslist": "since 2018, > 0.3%, not dead",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": "^24",
    "pnpm": "^11"
  },
  "scripts": {
    "start": "pnpm run dev",
    "dev": "vite",
    "prebuild": "pnpm run clean:dist",
    "build": "run-p check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "check": "vue-tsc -b",
    "lint": "run-s --continue-on-error lint:css lint:js",
    "lint:fix": "run-s --continue-on-error lint:css:fix lint:js:fix",
    "lint:css": "stylelint -f verbose \"**/*.{css,vue}\"",
    "lint:css:fix": "stylelint -f verbose --fix \"**/*.{css,vue}\"",
    "lint:css:ci": "stylelint --custom-formatter \"@csstools/stylelint-formatter-github\" \"**/*.{css,vue}\"",
    "lint:js": "eslint .",
    "lint:js:fix": "eslint . --fix",
    "clean:dist": "rimraf -I dist",
    "preclean": "pnpm run clean:dist",
    "clean": "rimraf -I -g \"**/node_modules\"",
    "clean:lockfile": "rimraf -I -g \"**/pnpm-lock.yaml\"",
    "clean:deep": "run-s clean:lockfile clean",
    "refresh": "pnpm run clean && pnpm install",
    "refresh:deep": "pnpm run clean:deep && pnpm install",
    "component:add": "pnpm exec shadcn-vue add"
  },
  "dependencies": {
    "@fontsource-variable/atkinson-hyperlegible-next": "^5.2.6",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/source-code-pro": "^5.2.7",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/vue-virtual": "^3.13.29",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.18.1",
    "caniuse-lite": "^1.0.30001799",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "dompurify": "^3.4.11",
    "emittery": "^2.0.0",
    "marked": "^18.0.5",
    "media-chrome": "^4.19.2",
    "pinia": "^3.0.4",
    "reka-ui": "^2.10.0",
    "remeda": "^2.39.0",
    "sanitize.css": "^13.0.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "ua-parser-js": "^2.0.10",
    "vaul-vue": "^0.4.1",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@csstools/stylelint-formatter-github": "^2.0.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@iconify-json/ph": "^1.2.2",
    "@iconify-json/ri": "^1.2.10",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@stylistic/stylelint-plugin": "^5.2.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/caniuse-lite": "^1.0.5",
    "@types/node": "^24.13.2",
    "@types/prismjs": "^1.26.6",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "eslint-import-resolver-custom-alias": "^1.3.2",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-n": "^18.1.0",
    "eslint-plugin-unicorn": "^68.0.0",
    "eslint-plugin-vue": "~10.9.2",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "lightningcss": "^1.32.0",
    "npm-run-all2": "^9.0.2",
    "rimraf": "^6.1.3",
    "shadcn-vue": "^2.7.4",
    "stylelint": "^17.13.0",
    "stylelint-config-clean-order": "^10.0.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-plugin-defensive-css": "^2.9.3",
    "stylelint-use-nesting": "^6.0.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.1.0",
    "vite-plugin-toml": "^0.9.0",
    "vite-plugin-vue-devtools": "^8.1.3",
    "vue-tsc": "^3.3.5"
  }
}
